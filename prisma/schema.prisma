generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  PROPOSAL
  NEGOTIATION
  WON
  LOST
}

enum LeadPriority {
  LOW
  MEDIUM
  HIGH
}

enum ProjectStatus {
  NOT_STARTED
  IN_PROGRESS
  ON_HOLD
  COMPLETED
  CANCELLED
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  IN_REVIEW
  DONE
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum InvoiceStatus {
  DRAFT
  SENT
  VIEWED
  PAID
  OVERDUE
  CANCELLED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum ReminderType {
  FOLLOW_UP
  MEETING
  DEADLINE
  PAYMENT
  OTHER
}

model Client {
  id          String   @id @default(cuid())
  userId      String
  name        String
  email       String
  phone       String?
  company     String?
  address     String?
  city        String?
  country     String?
  website     String?
  notes       String?
  avatarUrl   String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  projects    Project[]
  invoices    Invoice[]
  reminders   Reminder[]
  activities  Activity[]

  @@index([userId])
  @@index([email])
}

model Lead {
  id            String       @id @default(cuid())
  userId        String
  name          String
  email         String
  phone         String?
  company       String?
  position      String?
  source        String?
  status        LeadStatus   @default(NEW)
  priority      LeadPriority @default(MEDIUM)
  value         Float?
  notes         String?
  convertedAt   DateTime?
  convertedToId String?
  order         Int          @default(0)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  reminders   Reminder[]
  activities  Activity[]

  @@index([userId])
  @@index([status])
}

model Project {
  id          String        @id @default(cuid())
  userId      String
  clientId    String
  name        String
  description String?
  status      ProjectStatus @default(NOT_STARTED)
  startDate   DateTime?
  dueDate     DateTime?
  budget      Float?
  currency    String        @default("USD")
  notes       String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  client      Client     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  tasks       Task[]
  invoices    Invoice[]
  reminders   Reminder[]
  activities  Activity[]

  @@index([userId])
  @@index([clientId])
  @@index([status])
}

model Task {
  id          String       @id @default(cuid())
  userId      String
  projectId   String
  title       String
  description String?
  status      TaskStatus   @default(TODO)
  priority    TaskPriority @default(MEDIUM)
  dueDate     DateTime?
  order       Int          @default(0)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  project     Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([projectId])
  @@index([status])
}

model Invoice {
  id          String        @id @default(cuid())
  userId      String
  clientId    String
  projectId   String?
  number      String
  status      InvoiceStatus @default(DRAFT)
  issueDate   DateTime      @default(now())
  dueDate     DateTime
  subtotal    Float
  tax         Float         @default(0)
  discount    Float         @default(0)
  total       Float
  currency    String        @default("USD")
  notes       String?
  terms       String?
  paidAt      DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  client      Client        @relation(fields: [clientId], references: [id])
  project     Project?      @relation(fields: [projectId], references: [id])
  items       InvoiceItem[]
  payments    Payment[]
  activities  Activity[]

  @@index([userId])
  @@index([clientId])
  @@index([status])
  @@index([number])
}

model InvoiceItem {
  id          String   @id @default(cuid())
  invoiceId   String
  description String
  quantity    Float
  rate        Float
  amount      Float
  createdAt   DateTime @default(now())

  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

model Payment {
  id                String        @id @default(cuid())
  userId            String
  invoiceId         String
  amount            Float
  currency          String        @default("USD")
  status            PaymentStatus @default(PENDING)
  stripePaymentId   String?
  stripeSessionId   String?
  method            String?
  paidAt            DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  invoice           Invoice       @relation(fields: [invoiceId], references: [id])

  @@index([userId])
  @@index([invoiceId])
  @@index([stripePaymentId])
}

model Reminder {
  id          String       @id @default(cuid())
  userId      String
  clientId    String?
  leadId      String?
  projectId   String?
  title       String
  description String?
  type        ReminderType @default(FOLLOW_UP)
  dueDate     DateTime
  isDone      Boolean      @default(false)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  client      Client?      @relation(fields: [clientId], references: [id])
  lead        Lead?        @relation(fields: [leadId], references: [id])
  project     Project?     @relation(fields: [projectId], references: [id])

  @@index([userId])
  @@index([dueDate])
  @@index([isDone])
}

model Activity {
  id          String   @id @default(cuid())
  userId      String
  clientId    String?
  leadId      String?
  projectId   String?
  invoiceId   String?
  action      String
  description String?
  metadata    Json?
  createdAt   DateTime @default(now())

  client      Client?   @relation(fields: [clientId], references: [id])
  lead        Lead?     @relation(fields: [leadId], references: [id])
  project     Project?  @relation(fields: [projectId], references: [id])
  invoice     Invoice?  @relation(fields: [invoiceId], references: [id])

  @@index([userId])
  @@index([createdAt])
}
